import pygame

class SnackWarehouse:
    def __init__(self):
        pygame.init()
        self.SCREEN_WIDTH = 800
        self.SCREEN_HEIGHT = 600
        self.screen = pygame.display.set_mode((self.SCREEN_WIDTH, self.SCREEN_HEIGHT))
        pygame.display.set_caption("🍪 零食仓库管理员")
        
        self.font = pygame.font.Font(None, 48)
        self.small_font = pygame.font.Font(None, 32)
        
        # 创建储物格（数组）
        self.SLOTS = 8
        self.snacks = ["空"] * self.SLOTS
        self.snack_emojis = {
            "空": "📦",
            "饼干": "🍪",
            "糖果": "🍬",
            "巧克力": "🍫",
            "薯片": "🍿",
            "冰淇淋": "🍦",
            "蛋糕": "🎂",
            "布丁": "🍮",
            "果汁": "🧃"
        }
        
        self.available_snacks = ["饼干", "糖果", "巧克力", "薯片", 
                                "冰淇淋", "蛋糕", "布丁", "果汁"]
        self.message = "点击格子放入零食，右键取出零食！"
        self.selected_snack = 0  # 当前选择的零食索引
        
    def draw_warehouse(self):
        """画出仓库界面"""
        self.screen.fill((255, 248, 220))  # 米色背景
        
        # 标题
        title = self.font.render("🍪 零食仓库管理员 🍪", True, (139, 69, 19))
        self.screen.blit(title, (200, 20))
        
        # 画储物格
        slot_size = 100
        start_x = 100
        start_y = 150
        
        for i in range(self.SLOTS):
            x = start_x + (i % 4) * (slot_size + 20)
            y = start_y + (i // 4) * (slot_size + 40)
            
            # 画格子
            pygame.draw.rect(self.screen, (210, 180, 140), 
                           (x, y, slot_size, slot_size))
            pygame.draw.rect(self.screen, (0, 0, 0), 
                           (x, y, slot_size, slot_size), 3)
            
            # 显示格子编号
            slot_num = self.small_font.render(f"[{i}]", True, (0, 0, 0))
            self.screen.blit(slot_num, (x + 5, y + 5))
            
            # 显示零食或空箱
            if self.snacks[i] != "空":
                emoji = self.snack_emojis[self.snacks[i]]
                snack_text = self.font.render(emoji, True, (0, 0, 0))
                self.screen.blit(snack_text, (x + 25, y + 25))
                
                name_text = self.small_font.render(self.snacks[i], True, (0, 0, 0))
                self.screen.blit(name_text, (x + 10, y + 75))
            else:
                empty_text = self.font.render("📦", True, (150, 150, 150))
                self.screen.blit(empty_text, (x + 25, y + 25))
        
        # 零食选择区
        select_y = 450
        select_text = self.small_font.render("可选零食（按← →选择）:", True, (0, 0, 0))
        self.screen.blit(select_text, (100, select_y))
        
        for i, snack in enumerate(self.available_snacks):
            x = 100 + i * 90
            y = select_y + 40
            
            # 高亮当前选择
            if i == self.selected_snack:
                pygame.draw.rect(self.screen, (255, 255, 0), 
                               (x - 5, y - 5, 80, 80))
            
            emoji = self.snack_emojis[snack]
            snack_text = self.font.render(emoji, True, (0, 0, 0))
            self.screen.blit(snack_text, (x + 15, y + 10))
        
        # 提示信息
        msg = self.small_font.render(self.message, True, (100, 100, 100))
        self.screen.blit(msg, (150, 550))
        
        pygame.display.flip()
    
    def add_snack(self, slot_index):
        """在指定格子放入零食"""
        if 0 <= slot_index < self.SLOTS:
            snack = self.available_snacks[self.selected_snack]
            if self.snacks[slot_index] == "空":
                self.snacks[slot_index] = snack
                self.message = f"在格子{slot_index}放入了{snack}！"
            else:
                self.message = f"格子{slot_index}已经有{self.snacks[slot_index]}了！"
    
    def remove_snack(self, slot_index):
        """从指定格子取出零食"""
        if 0 <= slot_index < self.SLOTS:
            if self.snacks[slot_index] != "空":
                removed = self.snacks[slot_index]
                self.snacks[slot_index] = "空"
                self.message = f"从格子{slot_index}取出了{removed}！"
            else:
                self.message = f"格子{slot_index}是空的！"
    
    def run(self):
        """主游戏循环"""
        running = True
        
        while running:
            self.draw_warehouse()
            
            for event in pygame.event.get():
                if event.type == pygame.QUIT:
                    running = False
                
                if event.type == pygame.KEYDOWN:
                    if event.key == pygame.K_LEFT:
                        self.selected_snack = max(0, self.selected_snack - 1)
                    elif event.key == pygame.K_RIGHT:
                        self.selected_snack = min(len(self.available_snacks) - 1, 
                                                  self.selected_snack + 1)
                
                if event.type == pygame.MOUSEBUTTONDOWN:
                    x, y = event.pos
                    
                    # 检查点击了哪个格子
                    slot_size = 100
                    start_x = 100
                    start_y = 150
                    
                    for i in range(self.SLOTS):
                        slot_x = start_x + (i % 4) * (slot_size + 20)
                        slot_y = start_y + (i // 4) * (slot_size + 40)
                        
                        if (slot_x <= x <= slot_x + slot_size and 
                            slot_y <= y <= slot_y + slot_size):
                            
                            if event.button == 1:  # 左键放入
                                self.add_snack(i)
                            elif event.button == 3:  # 右键取出
                                self.remove_snack(i)
            
            pygame.display.flip()
        
        pygame.quit()

if __name__ == "__main__":
    game = SnackWarehouse()
    game.run()
四、教学建议
每节课的教学流程

真人游戏热身（5 分钟）
用身体动作演示算法
比如冒泡排序：让小朋友排成一排，相邻的比身高交换
电脑游戏演示（15 分钟）
老师先演示游戏操作
边玩边解释 “为什么这样做”
自由探索（10 分钟）
小朋友自己玩游戏
鼓励他们提出 “如果... 会怎样” 的问题
总结分享（5 分钟）
用简单的话总结学到的概念
比如：“今天我们学会了，排好队可以让我们更快找到东西！”
教学话术参考

讲查找算法时：

不说 “线性查找”，说 “一个一个找”
不说 “二分查找”，说 “聪明的猜法” 或 “从中间开始猜”

讲排序算法时：

不说 “冒泡排序”，说 “气泡升空法”
不说 “选择排序”，说 “挑最矮的小朋友站前面”

讲数据结构时：

不说 “数组”，说 “一排小格子”
不说 “索引”，说 “第几个位置”
扩展活动

画图理解：让小朋友用画笔画下排序的过程
故事时间：编一个 “小矮人排队” 的故事
亲子作业：回家和爸爸妈妈玩 “猜数字” 游戏

这套方案完全避免了抽象概念，所有游戏都有趣、直观、互动性强，非常适合二年级小朋友！
