"""
猜数字大冒险 - 理解查找策略
演示线性查找 vs 二分查找
"""

import pygame
import random

# 初始化
pygame.init()
SCREEN_WIDTH = 900
SCREEN_HEIGHT = 700

class GuessNumberGame:
    def __init__(self):
        self.screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))
        pygame.display.set_caption("🔍 猜数字大冒险")
        self.font_big = pygame.font.Font(None, 64)
        self.font_medium = pygame.font.Font(None, 48)
        self.font_small = pygame.font.Font(None, 36)
        
        # 游戏状态
        self.reset_game()
        
    def reset_game(self):
        """重置游戏"""
        self.secret_number = random.randint(1, 100)
        self.guesses_linear = 0
        self.guesses_binary = 0
        self.current_guess_linear = 1
        self.current_guess_binary = 50
        self.low_binary = 1
        self.high_binary = 100
        self.message = "用两种方法猜数字，看谁用的次数少！"
        self.game_over = False
        
    def draw_game(self):
        """画出游戏界面"""
        self.screen.fill((240, 248, 255))  # 淡蓝色背景
        
        # 标题
        title = self.font_big.render("🔍 猜数字大冒险", True, (0, 0, 139))
        self.screen.blit(title, (200, 20))
        
        # 秘密数字（隐藏）
        secret_text = self.font_small.render("???", True, (255, 0, 0))
        self.screen.blit(secret_text, (SCREEN_WIDTH//2 - 30, 100))
        
        # 线性查找区域
        pygame.draw.rect(self.screen, (255, 228, 225), (50, 150, 350, 400))
        pygame.draw.rect(self.screen, (0, 0, 0), (50, 150, 350, 400), 2)
        
        linear_title = self.font_medium.render("方法1: 一个一个试", True, (0, 0, 0))
        self.screen.blit(linear_title, (60, 160))
        
        linear_num = self.font_big.render(f"{self.current_guess_linear}", 
                                          True, (255, 69, 0))
        self.screen.blit(linear_num, (200, 250))
        
        linear_steps = self.font_small.render(
            f"已经猜了: {self.guesses_linear}次", True, (0, 0, 0))
        self.screen.blit(linear_steps, (100, 350))
        
        # 二分查找区域
        pygame.draw.rect(self.screen, (230, 255, 230), (500, 150, 350, 400))
        pygame.draw.rect(self.screen, (0, 0, 0), (500, 150, 350, 400), 2)
        
        binary_title = self.font_medium.render("方法2: 聪明的猜法", True, (0, 0, 0))
        self.screen.blit(binary_title, (510, 160))
        
        binary_num = self.font_big.render(f"{self.current_guess_binary}", 
                                          True, (34, 139, 34))
        self.screen.blit(binary_num, (650, 250))
        
        range_text = self.font_small.render(
            f"范围: {self.low_binary} - {self.high_binary}", True, (0, 0, 0))
        self.screen.blit(range_text, (550, 350))
        
        binary_steps = self.font_small.render(
            f"已经猜了: {self.guesses_binary}次", True, (0, 0, 0))
        self.screen.blit(binary_steps, (550, 400))
        
        # 提示信息
        msg = self.font_small.render(self.message, True, (100, 100, 100))
        self.screen.blit(msg, (150, 600))
        
        # 操作提示
        hint = self.font_small.render("按空格键让两种方法各猜一次", True, (0, 0, 0))
        self.screen.blit(hint, (200, 650))
        
        pygame.display.flip()
    
    def linear_guess(self):
        """线性查找：一个一个试"""
        if self.current_guess_linear <= 100:
            self.guesses_linear += 1
            if self.current_guess_linear == self.secret_number:
                self.message = f"方法1用了{self.guesses_linear}次找到答案！"
                return True
            self.current_guess_linear += 1
        return False
    
    def binary_guess(self):
        """二分查找：每次猜中间值"""
        if self.low_binary <= self.high_binary:
            self.current_guess_binary = (self.low_binary + self.high_binary) // 2
            self.guesses_binary += 1
            
            if self.current_guess_binary == self.secret_number:
                self.message = f"方法2只用了{self.guesses_binary}次就找到答案！"
                return True
            elif self.current_guess_binary < self.secret_number:
                self.low_binary = self.current_guess_binary + 1
            else:
                self.high_binary = self.current_guess_binary - 1
        return False
    
    def run(self):
        """主游戏循环"""
        running = True
        clock = pygame.time.Clock()
        
        while running:
            self.draw_game()
            
            for event in pygame.event.get():
                if event.type == pygame.QUIT:
                    running = False
                
                if event.type == pygame.KEYDOWN:
                    if event.key == pygame.K_SPACE and not self.game_over:
                        # 两种方法各猜一次
                        linear_found = self.linear_guess()
                        binary_found = self.binary_guess()
                        
                        if linear_found or binary_found:
                            self.game_over = True
                    
                    if event.key == pygame.K_r:
                        self.reset_game()
                        self.game_over = False
            
            clock.tick(30)
        
        pygame.quit()

if __name__ == "__main__":
    game = GuessNumberGame()
    game.run()
第 3 课：气泡升空记（冒泡排序可视化）

"""
气泡升空记 - 冒泡排序可视化
让小朋友看到数字像气泡一样浮到正确位置
"""

import pygame
import random
import time

class BubbleSortGame:
    def __init__(self):
        pygame.init()
        self.SCREEN_WIDTH = 1000
        self.SCREEN_HEIGHT = 600
        self.screen = pygame.display.set_mode((self.SCREEN_WIDTH, self.SCREEN_HEIGHT))
        pygame.display.set_caption("🫧 气泡升空记 - 冒泡排序")
        
        self.font = pygame.font.Font(None, 48)
        self.small_font = pygame.font.Font(None, 36)
        
        # 创建随机高度的柱子
        self.NUM_BARS = 8
        self.bars = []
        self.reset_bars()
        
        # 排序状态
        self.sorting = False
        self.i = 0
        self.j = 0
        self.comparisons = 0
        self.swaps = 0
        self.message = "按空格键开始排序，看气泡如何升空！"
        
        self.COLORS = {
            'default': (100, 149, 237),  # 矢车菊蓝
            'comparing': (255, 255, 0),   # 黄色
            'swapping': (255, 69, 0),     # 红橙色
            'sorted': (50, 205, 50)       # 绿色
        }
    
    def reset_bars(self):
        """创建随机高度的柱子"""
        heights = list(range(50, 400, 50))
        random.shuffle(heights)
        self.bars = [{'height': h, 'color': self.COLORS['default']} 
                     for h in heights]
        self.bar_colors = [self.COLORS['default']] * self.NUM_BARS
    
    def draw_bars(self):
        """画出所有柱子"""
        self.screen.fill((255, 255, 255))
        
        # 标题
        title = self.font.render("🫧 气泡升空记 🫧", True, (0, 0, 139))
        self.screen.blit(title, (300, 20))
        
        # 画柱子
        bar_width = 80
        spacing = 30
        start_x = (self.SCREEN_WIDTH - (bar_width + spacing) * self.NUM_BARS) // 2
        
        for i, bar in enumerate(self.bars):
            x = start_x + i * (bar_width + spacing)
            y = self.SCREEN_HEIGHT - bar['height'] - 100
            
            # 画柱子
            pygame.draw.rect(self.screen, self.bar_colors[i], 
                           (x, y, bar_width, bar['height']))
            pygame.draw.rect(self.screen, (0, 0, 0), 
                           (x, y, bar_width, bar['height']), 2)
            
            # 显示高度值
            height_text = self.small_font.render(str(bar['height']), 
                                                True, (0, 0, 0))
            text_x = x + bar_width//2 - 20
            text_y = y - 40
            self.screen.blit(height_text, (text_x, text_y))
            
            # 画气泡效果（在比较的柱子上方）
            if self.bar_colors[i] == self.COLORS['comparing']:
                pygame.draw.circle(self.screen, (173, 216, 230), 
                                 (x + bar_width//2, y - 60), 15)
                pygame.draw.circle(self.screen, (173, 216, 230), 
                                 (x + bar_width//2 + 10, y - 50), 10)
        
        # 统计信息
        stats = self.small_font.render(
            f"比较次数: {self.comparisons}  交换次数: {self.swaps}", 
            True, (0, 0, 0))
        self.screen.blit(stats, (250, 500))
        
        # 提示信息
        msg = self.small_font.render(self.message, True, (100, 100, 100))
        self.screen.blit(msg, (200, 550))
        
        pygame.display.flip()
    
    def bubble_sort_step(self):
        """执行冒泡排序的一步"""
        if self.i < self.NUM_BARS - 1:
            if self.j < self.NUM_BARS - 1 - self.i:
                # 重置颜色
                for k in range(self.NUM_BARS):
                    if k >= self.NUM_BARS - self.i:
                        self.bar_colors[k] = self.COLORS['sorted']
                    else:
                        self.bar_colors[k] = self.COLORS['default']
                
                # 比较相邻的两个
                self.bar_colors[self.j] = self.COLORS['comparing']
                self.bar_colors[self.j + 1] = self.COLORS['comparing']
                self.comparisons += 1
                
                # 如果前面的比后面的大，交换
                if self.bars[self.j]['height'] > self.bars[self.j + 1]['height']:
                    self.bar_colors[self.j] = self.COLORS['swapping']
                    self.bar_colors[self.j + 1] = self.COLORS['swapping']
                    self.bars[self.j], self.bars[self.j + 1] = \
                        self.bars[self.j + 1], self.bars[self.j]
                    self.swaps += 1
                    self.message = f"交换！{self.bars[self.j+1]['height']}和{self.bars[self.j]['height']}"
                
                self.j += 1
                return True
            else:
                self.j = 0
                self.i += 1
                self.message = f"第{self.i}个气泡升到正确位置！"
                return True
        else:
            # 排序完成
            for k in range(self.NUM_BARS):
                self.bar_colors[k] = self.COLORS['sorted']
            self.message = "🎉 所有气泡都升空了！排序完成！🎉"
            self.sorting = False
            return False
    
    def run(self):
        """主游戏循环"""
        running = True
        clock = pygame.time.Clock()
        step_delay = 500  # 毫秒
        last_step_time = 0
        
        while running:
            current_time = pygame.time.get_ticks()
            
            for event in pygame.event.get():
                if event.type == pygame.QUIT:
                    running = False
                
                if event.type == pygame.KEYDOWN:
                    if event.key == pygame.K_SPACE:
                        if not self.sorting:
                            self.sorting = True
                            self.i = 0
                            self.j = 0
                            self.comparisons = 0
                            self.swaps = 0
                            self.message = "开始排序！"
                    
                    if event.key == pygame.K_r:
                        self.reset_bars()
                        self.sorting = False
                        self.i = 0
                        self.j = 0
                        self.comparisons = 0
                        self.swaps = 0
                        self.message = "按空格键开始排序，看气泡如何升空！"
            
            # 自动执行排序步骤
            if self.sorting and current_time - last_step_time > step_delay:
                self.bubble_sort_step()
                last_step_time = current_time
            
            self.draw_bars()
            clock.tick(60)
        
        pygame.quit()

if __name__ == "__main__":
    game = BubbleSortGame()
    game.run()
