第 1 课：整理书包大作战（认识顺序）

真人版游戏：让 5 个小朋友拿不同大小的书，比赛谁能最快排好。

电脑版游戏：

"""
整理书包大作战 - 认识顺序
适合二年级小朋友的顺序概念游戏
"""

import pygame
import random
import time

# 初始化Pygame
pygame.init()

# 游戏设置
SCREEN_WIDTH = 800
SCREEN_HEIGHT = 600
WHITE = (255, 255, 255)
BLACK = (0, 0, 0)
RAINBOW = [
    (255, 0, 0),     # 红
    (255, 165, 0),   # 橙
    (255, 255, 0),   # 黄
    (0, 255, 0),     # 绿
    (0, 127, 255),   # 蓝
    (139, 0, 255)    # 紫
]

class SchoolBagGame:
    def __init__(self):
        self.screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))
        pygame.display.set_caption("🎒 整理书包大作战")
        self.font = pygame.font.Font(None, 48)
        self.small_font = pygame.font.Font(None, 36)
        
        # 创建要整理的"书本"（不同高度的矩形）
        self.books = []
        for i in range(6):
            height = random.randint(100, 300)
            self.books.append({
                'height': height,
                'color': RAINBOW[i],
                'name': ['数学书', '语文书', '英语书', '科学书', '美术书', '音乐书'][i]
            })
        
        self.sorted_books = sorted(self.books, key=lambda x: x['height'])
        self.current_order = self.books.copy()
        self.attempts = 0
        self.message = "点击两本书交换位置，从矮到高排好！"
        
    def draw_books(self):
        """画出所有书本"""
        self.screen.fill(WHITE)
        
        # 画标题
        title = self.font.render("🎒 整理书包大作战 🎒", True, BLACK)
        self.screen.blit(title, (200, 20))
        
        # 画提示信息
        msg = self.small_font.render(self.message, True, (100, 100, 100))
        self.screen.blit(msg, (150, 70))
        
        # 画书本
        for i, book in enumerate(self.current_order):
            x = 100 + i * 110
            y = SCREEN_HEIGHT - book['height'] - 50
            
            # 画书本（彩色矩形）
            pygame.draw.rect(self.screen, book['color'], 
                           (x, y, 80, book['height']))
            pygame.draw.rect(self.screen, BLACK, (x, y, 80, book['height']), 2)
            
            # 画书名
            name_text = self.small_font.render(book['name'], True, BLACK)
            self.screen.blit(name_text, (x + 5, y + 10))
            
            # 画高度标签
            height_text = self.small_font.render(f"{book['height']}", True, BLACK)
            self.screen.blit(height_text, (x + 20, y + book['height']//2))
        
        # 画步骤计数
        steps = self.small_font.render(f"交换次数: {self.attempts}", True, BLACK)
        self.screen.blit(steps, (300, 550))
        
        pygame.display.flip()
    
    def swap_books(self, i, j):
        """交换两本书的位置"""
        self.current_order[i], self.current_order[j] = \
            self.current_order[j], self.current_order[i]
        self.attempts += 1
    
    def check_sorted(self):
        """检查是否排好序"""
        heights = [book['height'] for book in self.current_order]
        if heights == sorted(heights):
            return True
        return False
    
    def run(self):
        """主游戏循环"""
        running = True
        selected = None
        clock = pygame.time.Clock()
        
        while running:
            self.draw_books()
            
            for event in pygame.event.get():
                if event.type == pygame.QUIT:
                    running = False
                
                if event.type == pygame.MOUSEBUTTONDOWN:
                    x, y = event.pos
                    
                    # 检查点击了哪本书
                    clicked_book = None
                    for i, book in enumerate(self.current_order):
                        book_x = 100 + i * 110
                        book_y = SCREEN_HEIGHT - book['height'] - 50
                        
                        if (book_x <= x <= book_x + 80 and 
                            book_y <= y <= book_y + book['height']):
                            clicked_book = i
                            break
                    
                    if clicked_book is not None:
                        if selected is None:
                            selected = clicked_book
                            self.message = f"已选择{self.current_order[selected]['name']}，再选一本交换"
                        else:
                            self.swap_books(selected, clicked_book)
                            selected = None
                            self.message = "点击两本书交换位置，从矮到高排好！"
                            
                            if self.check_sorted():
                                self.message = f"🎉 太棒了！你用{self.attempts}次交换整理好了书包！🎉"
            
            clock.tick(30)
        
        pygame.quit()

# 运行游戏
if __name__ == "__main__":
    game = SchoolBagGame()
    game.run()
第 2 课：猜数字大冒险（查找算法）

