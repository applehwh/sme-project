            eye_y = head_y - 5
            pygame.draw.circle(self.screen, (0, 0, 0), 
                             (x + dwarf_width//2 - 8, eye_y), 3)
            pygame.draw.circle(self.screen, (0, 0, 0), 
                             (x + dwarf_width//2 + 8, eye_y), 3)
            
            # 画微笑
            smile_points = [
                (x + dwarf_width//2 - 10, eye_y + 8),
                (x + dwarf_width//2, eye_y + 13),
                (x + dwarf_width//2 + 10, eye_y + 8)
            ]
            pygame.draw.lines(self.screen, (0, 0, 0), False, smile_points, 2)
            
            # 显示名字和身高
            name_text = self.small_font.render(dwarf['name'], True, (0, 0, 0))
            self.screen.blit(name_text, (x + 5, y + 10))
            
            height_text = self.small_font.render(f"{dwarf['height']}cm", 
                                                True, (0, 0, 0))
            self.screen.blit(height_text, (x + 15, y + dwarf['height']//2))
        
        # 统计信息
        stats = self.small_font.render(
            f"比较次数: {self.comparisons}  交换次数: {self.swaps}", 
            True, (0, 0, 0))
        self.screen.blit(stats, (250, 480))
        
        # 提示信息
        msg = self.small_font.render(self.message, True, (100, 100, 100))
        self.screen.blit(msg, (150, 530))
        
        pygame.display.flip()
    
    def selection_sort_step(self):
        """执行选择排序的一步"""
        if self.current_pos < self.NUM_DWARFS - 1:
            # 第一步：开始新的搜索
            if self.search_pos == self.current_pos:
                self.min_pos = self.current_pos
                self.search_pos = self.current_pos + 1
                # 重置颜色
                for i in range(self.NUM_DWARFS):
                    if i < self.current_pos:
                        self.dwarf_colors[i] = self.COLORS['sorted']
                    elif i == self.current_pos:
                        self.dwarf_colors[i] = self.COLORS['current']
                    elif i == self.min_pos:
                        self.dwarf_colors[i] = self.COLORS['minimum']
                    else:
                        self.dwarf_colors[i] = self.COLORS['default']
                self.message = f"在位置{self.current_pos}寻找最矮的小矮人..."
                return True
            
            # 继续搜索
            if self.search_pos < self.NUM_DWARFS:
                # 更新颜色
                for i in range(self.NUM_DWARFS):
                    if i < self.current_pos:
                        self.dwarf_colors[i] = self.COLORS['sorted']
                    elif i == self.current_pos:
                        self.dwarf_colors[i] = self.COLORS['current']
                    elif i == self.min_pos:
                        self.dwarf_colors[i] = self.COLORS['minimum']
                    elif i == self.search_pos:
                        self.dwarf_colors[i] = self.COLORS['searching']
                    else:
                        self.dwarf_colors[i] = self.COLORS['default']
                
                self.comparisons += 1
                # 比较当前搜索位置和最小值位置
                if self.dwarfs[self.search_pos]['height'] < \
                   self.dwarfs[self.min_pos]['height']:
                    self.min_pos = self.search_pos
                    self.message = f"发现更矮的小矮人：{self.dwarfs[self.min_pos]['name']} ({self.dwarfs[self.min_pos]['height']}cm)"
                else:
                    self.message = f"比较中... {self.dwarfs[self.search_pos]['name']} 不够矮"
                
                self.search_pos += 1
                return True
            else:
                # 搜索完成，交换
                if self.min_pos != self.current_pos:
                    self.swaps += 1
                    self.dwarfs[self.current_pos], self.dwarfs[self.min_pos] = \
                        self.dwarfs[self.min_pos], self.dwarfs[self.current_pos]
                    self.message = f"交换！{self.dwarfs[self.current_pos]['name']}站到前面"
                
                self.current_pos += 1
                self.search_pos = self.current_pos
                return True
        else:
            # 排序完成
            for i in range(self.NUM_DWARFS):
                self.dwarf_colors[i] = self.COLORS['sorted']
            self.message = "🎉 所有小矮人都排好队了！🎉"
            self.sorting = False
            return False
    
    def run(self):
        """主游戏循环"""
        running = True
        clock = pygame.time.Clock()
        step_delay = 800
        last_step_time = 0
        
        while running:
            current_time = pygame.time.get_ticks()
            
            for event in pygame.event.get():
                if event.type == pygame.QUIT:
                    running = False
                
                if event.type == pygame.KEYDOWN:
                    if event.key == pygame.K_SPACE:
                        if not self.sorting:
                            self.sorting = True
                            self.current_pos = 0
                            self.min_pos = 0
                            self.search_pos = 0
                            self.comparisons = 0
                            self.swaps = 0
                            self.message = "开始寻找最矮的小矮人！"
                    
                    if event.key == pygame.K_r:
                        self.reset_dwarfs()
                        self.sorting = False
                        self.current_pos = 0
                        self.comparisons = 0
                        self.swaps = 0
                        self.message = "按空格键开始，每次找到最矮的小矮人！"
            
            # 自动执行排序步骤
            if self.sorting and current_time - last_step_time > step_delay:
                self.selection_sort_step()
                last_step_time = current_time
            
            self.draw_dwarfs()
            clock.tick(60)
        
        pygame.quit()

if __name__ == "__main__":
    game = SelectionSortGame()
    game.run()
